# Production deployment template. Keep real secrets only in Railway.
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=https://win-crm.up.railway.app
# Optional. Leave blank to use the safe default iframe allowlist for HighLevel, LeadConnector, and app.win-crm.ai.
CUSTOM_PAGE_FRAME_ANCESTORS=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# LINE Official Account legacy/default fallback.
# Connected multi-tenant LINE channels use line_channels.channel_secret and channel_access_token.
LINE_CHANNEL_SECRET=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me

# GoHighLevel / LeadConnector
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=replace-me
GHL_CUSTOM_PROVIDER_ID=replace-me
GHL_OAUTH_CLIENT_ID=replace-me
GHL_OAUTH_CLIENT_SECRET=replace-me
GHL_OAUTH_REDIRECT_URI=https://win-crm.up.railway.app/oauth/callback
GHL_OAUTH_TOKEN_URL=https://services.leadconnectorhq.com/oauth/token
# HighLevel Marketplace App ID. Used to correlate signed AppInstall events with Company OAuth sessions.
GHL_MARKETPLACE_APP_ID=replace-me
# Confirmed production LINE provider payload. Do not change unless migrating providers.
GHL_INBOUND_MESSAGE_TYPE=Custom
GHL_SEND_CONVERSATION_PROVIDER_ID=true
# Contact writes use the selected location API mode. Inbound conversation message writes always use OAuth.
GHL_LOCATION_API_AUTH_MODE=private_integration
# Safe single-delivery rollback requires both settings together:
# GHL_WORKFLOW_LINE_DELIVERY_MODE=direct_legacy
# GHL_WORKFLOW_OUTBOUND_MIRROR_ENABLED=false
# direct_legacy with the outbound mirror enabled can restore the original direct LINE push plus
# provider callback duplicate-delivery path.
GHL_WORKFLOW_OUTBOUND_MIRROR_ENABLED=false
# provider_first dispatches through HighLevel so the custom conversation provider callback performs
# the only physical LINE push.
GHL_WORKFLOW_LINE_DELIVERY_MODE=direct_legacy

# Optional GHL custom fields.
GHL_LINE_USER_ID_FIELD_ID=
GHL_LINE_DISPLAY_NAME_FIELD_ID=

# Deprecated/testing only. Keep false in production.
GHL_ALLOW_PRIVATE_TOKEN_FALLBACK=false

# Required for this production setup because GHL_LOCATION_API_AUTH_MODE=private_integration.
GHL_PRIVATE_INTEGRATION_TOKEN=replace-me

# Recommended webhook hardening for outbound webhooks sent by HighLevel.
# Configure the same value in your custom conversation provider settings.
GHL_CUSTOM_PROVIDER_SECRET=change-this-long-random-secret

# Required for admin routes and protected production debug endpoints.
WEBHOOK_SHARED_SECRET=change-this-long-random-secret
