NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=https://api.win-crm.ai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# LINE Official Account
LINE_CHANNEL_SECRET=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me

# GoHighLevel / LeadConnector
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=replace-me
GHL_CUSTOM_PROVIDER_ID=replace-me
GHL_OAUTH_CLIENT_ID=replace-me
GHL_OAUTH_CLIENT_SECRET=replace-me
GHL_OAUTH_REDIRECT_URI=https://api.win-crm.ai/oauth/callback
GHL_OAUTH_TOKEN_URL=https://services.leadconnectorhq.com/oauth/token
# LINE behaves like an added SMS custom conversation channel in HighLevel.
# HighLevel docs say added SMS custom providers use type "SMS" with conversationProviderId.
GHL_INBOUND_MESSAGE_TYPE=SMS
# Keep oauth unless /debug/ghl-inbound-message-auth-matrix-test proves Private Integration reaches validation.
GHL_INBOUND_SEND_AUTH_MODE=oauth
GHL_LINE_USER_ID_FIELD_ID=
GHL_LINE_DISPLAY_NAME_FIELD_ID=

# Private Integration token is required only when GHL_INBOUND_SEND_AUTH_MODE=private_integration.
# Keep GHL_ALLOW_PRIVATE_TOKEN_FALLBACK=false in production; it is separate from the controlled inbound send mode.
GHL_ALLOW_PRIVATE_TOKEN_FALLBACK=false
GHL_PRIVATE_INTEGRATION_TOKEN=

# Optional webhook hardening for outbound webhooks sent by HighLevel.
# Configure the same value in your custom conversation provider settings.
GHL_CUSTOM_PROVIDER_SECRET=change-this-long-random-secret

# Optional internal admin endpoint secret for manually linking mappings.
WEBHOOK_SHARED_SECRET=change-this-long-random-secret
