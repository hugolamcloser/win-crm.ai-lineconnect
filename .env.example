NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=https://api.win-crm.ai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# LINE Official Account
LINE_CHANNEL_SECRET=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me

# GoHighLevel / LeadConnector
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_PRIVATE_INTEGRATION_TOKEN=replace-me
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=replace-me
GHL_CUSTOM_PROVIDER_ID=replace-me

# Optional webhook hardening for outbound webhooks sent by HighLevel.
# Configure the same value in your custom conversation provider settings.
GHL_CUSTOM_PROVIDER_SECRET=change-this-long-random-secret

# Optional internal admin endpoint secret for manually linking mappings.
WEBHOOK_SHARED_SECRET=change-this-long-random-secret
